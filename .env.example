ADH_ENVIRONMENT=development
ADH_HOST=0.0.0.0
ADH_PORT=9000
ADH_OLLAMA_BASE_URL=http://localhost:11434/v1
ADH_OLLAMA_API_KEY=ollama
ADH_OLLAMA_MODEL=qwen3.5:9b
# Per-pipeline model overrides (unset = falls back to ADH_OLLAMA_MODEL)
# ADH_OLLAMA_MODEL_CLASSIFIER=qwen3.5:9b
# ADH_OLLAMA_MODEL_EXTRACTOR=qwen3.5:9b
# ADH_OLLAMA_MODEL_WORKSPACE_CHAT=qwen3.5:14b
# Global num_ctx override for Ollama (unset = Ollama model default, often 2048)
# ADH_OLLAMA_NUM_CTX=
# Per-pipeline num_ctx overrides (unset = falls back to ADH_OLLAMA_NUM_CTX)
# ADH_OLLAMA_NUM_CTX_CLASSIFIER=
# ADH_OLLAMA_NUM_CTX_EXTRACTOR=
ADH_OLLAMA_NUM_CTX_WORKSPACE_CHAT=16384
ADH_REQUEST_TIMEOUT_SECONDS=300
ADH_OLLAMA_MAX_CONCURRENCY=1
ADH_CLASSIFIER_TEMPERATURE=0.1
ADH_EXTRACT_TEMPERATURE=0.1
ADH_MAX_TEXT_CHARACTERS=12000
ADH_PROMPTS_DIR=server/prompts
ADH_FILE_RULES_PATH=server/file_rules.yaml
ADH_LLM_LOG_DIR=server/logs/llm
ADH_VALIDATION_LOG_DIR=server/logs/validation
ADH_VALIDATION_REPORT_PATH=server/logs/validation/latest.json
ADH_LANCEDB_PATH=server/data/lancedb
ADH_UI_DOCUMENTS_PATH=server/data/ui_documents.jsonl
ADH_MOVE_HISTORY_PATH=server/data/move_history.jsonl
ADH_LANCEDB_TABLE_NAME=document_chunks
ADH_EMBEDDING_MODEL_NAME=nomic-ai/nomic-embed-text-v1.5
ADH_EMBEDDING_MODEL_REVISION=e5cf08aadaa33385f5990def41f7a23405aec398
ADH_EMBEDDING_DEVICE=cpu
ADH_EMBEDDING_BATCH_SIZE=16
ADH_EMBEDDING_TRUST_REMOTE_CODE=true
ADH_SEARCH_CHUNK_SIZE=900
ADH_SEARCH_CHUNK_OVERLAP=120
ADH_SEARCH_DEFAULT_LIMIT=5
ADH_SEARCH_CANDIDATE_LIMIT=20
ADH_CORS_ALLOWED_ORIGINS=["*"]
ADH_WHISPER_BASE_URL=http://ai-server2:8090
ADH_WHISPER_TIMEOUT_SECONDS=300
ADH_WHISPER_HOST=0.0.0.0
ADH_WHISPER_PORT=8090
ADH_WHISPER_MODEL_NAME=turbo
ADH_WHISPER_MODEL_LABEL=large-v3-turbo
ADH_WHISPER_DEVICE=cuda
ADH_WHISPER_COMPUTE_TYPE=float16
ADH_WHISPER_BEAM_SIZE=5
ADH_WHISPER_VAD_FILTER=true
ADH_WHISPER_WORD_TIMESTAMPS=true
